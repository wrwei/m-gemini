# Backend runtime configuration — copy to `.env` and fill in.
# No secrets are committed to the repository.

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/mogao_dt

# HTTP server
PORT=8008
BACKEND_URL=http://localhost:8008
NODE_ENV=development

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173

# JWT signing secret — REQUIRED in production (a random one is generated in dev)
JWT_SECRET=

# Default admin seed (scripts/seed-admin.js) — CHANGE THESE
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.org
ADMIN_FULLNAME=Administrator
ADMIN_PASSWORD=

# Sensor seed (scripts/seed-sensor.js)
SENSOR_NAME=
SENSOR_MODEL=
SENSOR_CAVE=
SENSOR_CHANNELS=temperature,humidity,lightKlux
