[%
// EGL template to generate a Mongoose service class from an EClass
// Parameters:
//   - eClass: The EClass to generate service for
//
// Services handle all business logic and database operations (CRUD).
// Follows the pattern from Principia prototype server/core/services.

var className = eClass.name;
var serviceName = eClass.name + "Service";
var modelName = eClass.name;
var varName = eClass.name.firstToLowerCase();

// Collect containment references for cascade operations
var containmentRefs = eClass.eAllReferences.select(r | r.containment and r.isMany());
%]
const { [%=modelName%] } = require('../models/[%=className%]');

/**
 * [%=serviceName%]
 * Handles CRUD operations for [%=className%] documents
 * Auto-generated from mogao_dt.ecore metamodel
 */
const [%=serviceName%] = {

    /**
     * Create a new [%=className%]
     */
    create: async (data) => {
        // Always generate gid server-side to prevent client-supplied collisions
        data.gid = '[%=varName%]-' + Date.now() + '-' + Math.random().toString(36).substring(2, 8);
        delete data._id;
        const [%=varName%] = await [%=modelName%].create(data);
        return [%=varName%];
    },

    /**
     * Get all [%=className%] documents.
     * Optional query: { page, limit, sort } for pagination + ordering.
     */
    getAll: async (query = {}) => {
        const { page, limit, sort } = query;
        let q = [%=modelName%].find();
        if (sort) q = q.sort(sort);
        if (page && limit) {
            const skip = (parseInt(page) - 1) * parseInt(limit);
            q = q.skip(skip).limit(parseInt(limit));
        }
        return q.exec();
    },

    /**
     * Get [%=className%] by ID
     */
    getById: async (id) => {
        const [%=varName%] = await [%=modelName%].findById(id);
        return [%=varName%];
    },

    /**
     * Get [%=className%] by GID
     */
    getByGid: async (gid) => {
        const [%=varName%] = await [%=modelName%].findOne({ gid });
        return [%=varName%];
    },

    /**
     * Update [%=className%] by ID
     */
    update: async (id, data) => {
        const [%=varName%] = await [%=modelName%].findByIdAndUpdate(id, data, { new: true, runValidators: true });
        return [%=varName%];
    },

    /**
     * Delete [%=className%] by ID
     */
    delete: async (id) => {
        const [%=varName%] = await [%=modelName%].findByIdAndDelete(id);
        return [%=varName%];
    },

    /**
     * Update [%=className%] by GID
     */
    updateByGid: async (gid, data) => {
        const [%=varName%] = await [%=modelName%].findOneAndUpdate({ gid }, data, { new: true, runValidators: true });
        return [%=varName%];
    },

    /**
     * Delete [%=className%] by GID
     */
    deleteByGid: async (gid) => {
        const [%=varName%] = await [%=modelName%].findOneAndDelete({ gid });
        return [%=varName%];
    },
};

module.exports = [%=serviceName%];
