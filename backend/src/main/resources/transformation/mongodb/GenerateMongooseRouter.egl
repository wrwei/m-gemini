[%
// EGL template to generate an Express router from an EClass
// Parameters:
//   - eClass: The EClass to generate router for
//
// Routers map HTTP routes to controller methods.
// Follows the pattern from Principia prototype server/core/routers.

var className = eClass.name;
var controllerName = eClass.name + "Controller";
var routerName = eClass.name.firstToLowerCase() + "Router";
%]
const express = require('express');
const router = express.Router();
const [%=controllerName%] = require('../controllers/[%=controllerName%]');

/**
 * [%=className%] Routes
 * Auto-generated from mogao_dt.ecore metamodel
 *
 * POST   /              - Create a new [%=className%]
 * GET    /              - Get all [%=className%] documents
 * GET    /gid/:gid      - Get [%=className%] by GID
 * PUT    /gid/:gid      - Update [%=className%] by GID
 * DELETE /gid/:gid      - Delete [%=className%] by GID
 * GET    /:id           - Get [%=className%] by ID
 * PUT    /:id           - Update [%=className%] by ID
 * DELETE /:id           - Delete [%=className%] by ID
 *
 * The /gid/:gid routes are registered BEFORE the /:id routes so that
 * Express does not interpret the literal string "gid" as a Mongo ObjectId.
 */

router.post('/', [%=controllerName%].create);
router.get('/', [%=controllerName%].getAll);
router.get('/gid/:gid', [%=controllerName%].getByGid);
router.put('/gid/:gid', [%=controllerName%].updateByGid);
router.delete('/gid/:gid', [%=controllerName%].deleteByGid);
router.get('/:id', [%=controllerName%].getById);
router.put('/:id', [%=controllerName%].update);
router.delete('/:id', [%=controllerName%].delete);

module.exports = router;
